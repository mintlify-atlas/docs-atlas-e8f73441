  "keyFeatures": [
    "Spatiotemporal modeling combining Graph Neural Networks with RNN/LSTM/GRU for temporal sequences",
    "Support for multiple GNN architectures (GraphSAGE, GCN, GAT) with configurable layers",
    "TopK pooling for hierarchical graph representations",
    "Focal loss implementation for handling class imbalance in conversion prediction",
    "Time-aware prediction with temporal gap features",
    "Self-supervised pretraining for graph encoders",
    "5-fold cross-validation with stratified splits",
    "Support for both static (FC) and dynamic functional connectivity (DFC)",
    "Comprehensive evaluation with conversion-specific accuracy analysis"
  ],
  "publicApiSurface": [
    "FC_ADNIDataset - PyTorch Geometric dataset for functional connectivity graphs",
    "DFC_ADNIDataset - Dataset for dynamic functional connectivity",
    "GraphNeuralNetwork - Configurable GNN encoder with multiple layer types",
    "DynamicGraphNeuralNetwork - GNN for dynamic connectivity matrices",
    "TemporalTabGNNClassifier - LSTM-based temporal classifier",
    "GRUPredictor - GRU-based temporal model",
    "RNNPredictor - Basic RNN temporal model",
    "TemporalDataLoader - Custom DataLoader for variable-length temporal sequences",
    "FocalLoss - Focal loss for class imbalance",
    "GraphConverter - Utilities for graph construction",
    "temporal_gap_processor - Temporal feature normalization utilities",
    "conversion_analyzer - Conversion-specific accuracy analysis tools",
    "main.py - Training script with 5-fold cross-validation",
    "dfc_main.py - Training script for dynamic connectivity",
    "supervised_pretrain.py - Self-supervised encoder pretraining",
    "setup_temporal_data.py - Data preparation utilities"
  ]
}
